{% extends 'base.html.twig' %}
{% block title %}
	{{ page.titre }}
{% endblock %}

{% block body %}
	<section class="page-content page-{{ page.slug }}">
		<div class="container">
			<h1>{{ page.titre }}</h1>
			<div class="page-text">
				{{ page.contenu|raw }}
			</div>
		</div>
	</section>
{% endblock %}

