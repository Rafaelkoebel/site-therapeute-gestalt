{% extends 'base.html.twig' %}

{% block title %}Infos pratiques
{% endblock %}

{% block body %}
	<section class="page-content">
		<div class="container">
			<h1>Infos pratiques</h1>

			<ul>
				<li>
					<strong>
						Lieu :
					</strong>
					<a href="https://maps.app.goo.gl/eNvHFeygSjfxcXqe8" target="_blank">
						{{ info.lieu }}</a>
				</li>

				<li>
					<strong>Durée :</strong>
					{{ info.duree }}</li>
				<li>
					<strong>Tarif :</strong>
					{{ info.tarif }}
					€</li>
				<li>
					<strong>Rythme :</strong>
					{{ info.rythme }}</li>
				<li>
					<strong>Paiement :</strong>
					{{ info.modalitesPaiement }}</li>
				<li>
					<strong>Annulation :</strong>
					{{ info.cadreAnnulation }}</li>
			</ul>

		</div>
	</div>
{% endblock %}

